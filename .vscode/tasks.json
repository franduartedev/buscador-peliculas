{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build & Run C++",
      "type": "shell",
      "command": "/bin/bash",
      "args": [
        "-c",
        "g++ '${file}' -o '${fileDirname}/${fileBasenameNoExtension}' && '${fileDirname}/${fileBasenameNoExtension}'"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}